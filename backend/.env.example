# ===========================================
# 任务调度平台 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# 后端服务
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL 连接
MYSQL_HOST=<数据库地址>
MYSQL_PORT=<数据库端口>
MYSQL_USER=<数据库用户>
MYSQL_PASSWORD=<数据库密码>
MYSQL_DATABASE=<数据库名>

# Redis 连接
REDIS_HOST=<Redis 地址>
REDIS_PORT=<Redis 端口>
REDIS_DB=0
